---
// Sección: Funcionalidades Core
const features = [
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><rect x="3" y="3" width="7" height="7" rx="2" stroke="currentColor" stroke-width="1.5"/><rect x="3" y="14" width="7" height="7" rx="2" stroke="currentColor" stroke-width="1.5"/><rect x="14" y="3" width="7" height="7" rx="2" stroke="currentColor" stroke-width="1.5"/><rect x="14" y="14" width="7" height="7" rx="2" stroke="currentColor" stroke-width="1.5"/></svg>`,
    title: 'POS Híbrido Profesional',
    description: 'Gestión unificada de Ventas Rápidas, Mesas (Salón) y Delivery en una sola interfaz reactiva. Tres modos, una sola plataforma.',
    tag: 'Core'
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.5"/><path d="M12 7v5l3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>`,
    title: 'Sistema de Mesas Dinámico',
    description: 'Control visual de ocupación, cambio de mesas, unión de tickets y gestión de cuentas abiertas. Visualiza tu salón en tiempo real.',
    tag: 'Operaciones'
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M4 7h16M4 12h16M4 17h10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><circle cx="19" cy="17" r="2" stroke="currentColor" stroke-width="1.5"/></svg>`,
    title: 'KDS — Kitchen Display System',
    description: 'Pantalla interactiva en tiempo real para cocineros con alertas sonoras integradas y optimización de flujos de trabajo en cocina.',
    tag: 'Tiempo Real'
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M20 7H4a2 2 0 00-2 2v6a2 2 0 002 2h16a2 2 0 002-2V9a2 2 0 00-2-2z" stroke="currentColor" stroke-width="1.5"/><path d="M16 17v2M8 17v2M12 7V5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>`,
    title: 'Gestión Integral de Stock',
    description: 'Control de inventario avanzado basado en recetas. Cada venta descarga automáticamente los insumos utilizados. Control de insumos críticos.',
    tag: 'Inventario'
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>`,
    title: 'Auditoría de Cajas',
    description: 'Apertura, arqueo y cierre de caja por turno. Procesos estrictos de control financiero con trazabilidad completa del flujo de efectivo.',
    tag: 'Finanzas'
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M3 3v18h18" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><path d="M7 14l4-4 4 4 5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
    title: 'Dashboard Analítico',
    description: 'Visualización de ingresos (Bs / USD), productos estrella y rendimiento histórico. Exportación directa a Excel/CSV.',
    tag: 'Business Intelligence'
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><circle cx="9" cy="7" r="4" stroke="currentColor" stroke-width="1.5"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>`,
    title: 'Control de Permisos por Roles',
    description: 'Perfiles específicos para Admin, Cajero, Cocina y Repartidor. Seguridad granular para proteger la información de tu negocio.',
    tag: 'Seguridad'
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M10 13a5 5 0 007.54.54l3-3a5 5 0 00-7.07-7.07l-1.72 1.71" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><path d="M14 11a5 5 0 00-7.54-.54l-3 3a5 5 0 007.07 7.07l1.71-1.71" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>`,
    title: 'Arquitectura de Webhooks',
    description: 'Estructura técnica flexible lista para conectar con cualquier servicio o API externa. Integración sin límites con terceros.',
    tag: 'Integraciones'
  },
];
---

<section class="section features-section" id="funcionalidades">
  <div class="container">
    <div class="section-header reveal">
      <span class="section-label">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M2 4h12M2 8h12M2 12h8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        Funcionalidades Core
      </span>
      <h2 class="section-title">Una Plataforma Completa.<br/><span class="gradient-text">Nada Falta. Todo Funciona.</span></h2>
      <p class="section-subtitle">8 módulos profesionales integrados en una arquitectura escalable construida con las mejores tecnologías del mercado.</p>
    </div>

    <div class="features-grid">
      {features.map((feature, i) => (
        <div class={`feature-card glass-card reveal reveal-delay-${(i % 4) + 1}`}>
          <div class="feature-tag">{feature.tag}</div>
          <div class="feature-icon" set:html={feature.icon} />
          <h3 class="feature-title">{feature.title}</h3>
          <p class="feature-description">{feature.description}</p>
        </div>
      ))}
    </div>

    <div class="tech-stack reveal">
      <p class="tech-label">Stack Tecnológico Élite</p>
      <div class="tech-badges">
        <span class="tech-badge">Laravel 12</span>
        <span class="tech-badge">Vue 3</span>
        <span class="tech-badge">Inertia.js</span>
        <span class="tech-badge">Vite</span>
        <span class="tech-badge">MySQL</span>
        <span class="tech-badge">WebSockets</span>
      </div>
    </div>
  </div>
</section>

<style>
  .features-section {
    position: relative;
  }

  .section-header {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    margin-bottom: 4rem;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.25rem;
  }

  .feature-card {
    padding: 2rem 1.75rem;
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .feature-tag {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--accent-cyan);
    background: rgba(0, 212, 255, 0.08);
    padding: 0.3rem 0.75rem;
    border-radius: 100px;
    align-self: flex-start;
    border: 1px solid rgba(0, 212, 255, 0.12);
  }

  .feature-icon {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--accent-pink);
    background: rgba(255, 45, 117, 0.08);
    border: 1px solid rgba(255, 45, 117, 0.12);
    border-radius: 14px;
    margin: 0.5rem 0;
  }

  .feature-title {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--text-primary);
  }

  .feature-description {
    font-size: 0.88rem;
    color: var(--text-secondary);
    line-height: 1.7;
  }

  /* Tech Stack */
  .tech-stack {
    margin-top: 4rem;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
  }

  .tech-label {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--text-muted);
  }

  .tech-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: center;
  }

  .tech-badge {
    padding: 0.5rem 1.25rem;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 100px;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--text-secondary);
    transition: all var(--transition-base);
  }

  .tech-badge:hover {
    border-color: var(--accent-pink);
    color: var(--text-primary);
    background: rgba(255, 45, 117, 0.05);
  }

  @media (max-width: 1024px) {
    .features-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .features-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
