---
// Sección: CTA Final + Agendar Demo
---

<section class="section cta-section" id="demo">
  <div class="cta-bg-effects" aria-hidden="true">
    <div class="cta-orb cta-orb-1"></div>
    <div class="cta-orb cta-orb-2"></div>
  </div>

  <div class="container">
    <div class="cta-card glass-card reveal">
      <div class="cta-inner">
        <span class="cta-label">
          <span class="cta-dot"></span>
          Agenda sin compromiso
        </span>
        <h2 class="cta-title">
          ¿Listo para ser Dueño<br/>
          <span class="gradient-text">de Tu Tecnología?</span>
        </h2>
        <p class="cta-description">
          Agenda una demostración en vivo de 30 minutos. Te mostramos el sistema funcionando en tiempo real 
          y resolvemos todas tus dudas técnicas y comerciales.
        </p>

        <form class="cta-form" id="demo-form">
          <div class="form-row">
            <div class="form-group">
              <label for="name" class="form-label">Nombre completo</label>
              <input type="text" id="name" name="name" class="form-input" placeholder="Tu nombre" required />
            </div>
            <div class="form-group">
              <label for="email" class="form-label">Email corporativo</label>
              <input type="email" id="email" name="email" class="form-input" placeholder="tu@empresa.com" required />
            </div>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label for="company" class="form-label">Empresa / Proyecto</label>
              <input type="text" id="company" name="company" class="form-input" placeholder="Nombre de tu empresa" />
            </div>
            <div class="form-group">
              <label for="role" class="form-label">Tu perfil</label>
              <select id="role" name="role" class="form-input form-select">
                <option value="" disabled selected>Selecciona tu perfil</option>
                <option value="integrador">Integrador IT / Agencia</option>
                <option value="cadena">Cadena de Restaurantes</option>
                <option value="restaurante">Restaurante Individual</option>
                <option value="franquicia">Franquicia</option>
                <option value="otro">Otro</option>
              </select>
            </div>
          </div>
          <button type="submit" class="cta-button cta-submit" id="demo-submit">
            <span>Agendar Demostración en Vivo</span>
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M4 10h12M12 6l4 4-4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
        </form>

        <p class="cta-disclaimer">
          Sin compromiso. Sin tarjeta de crédito. Respuesta en menos de 24 horas.
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  .cta-section {
    position: relative;
    overflow: hidden;
  }

  .cta-bg-effects {
    position: absolute;
    inset: 0;
    overflow: hidden;
    z-index: 0;
  }

  .cta-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(100px);
  }

  .cta-orb-1 {
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(255, 45, 117, 0.12) 0%, transparent 70%);
    top: -20%;
    right: -10%;
  }

  .cta-orb-2 {
    width: 350px;
    height: 350px;
    background: radial-gradient(circle, rgba(255, 214, 10, 0.08) 0%, transparent 70%);
    bottom: -15%;
    left: -5%;
  }

  .cta-card {
    padding: 4rem;
    text-align: center;
    position: relative;
    z-index: 1;
    border-color: rgba(255, 45, 117, 0.12);
    background: linear-gradient(
      135deg,
      rgba(255, 45, 117, 0.03) 0%,
      rgba(0, 212, 255, 0.02) 100%
    );
  }

  .cta-card:hover {
    transform: none;
  }

  .cta-inner {
    max-width: 680px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .cta-label {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--accent-green);
    margin-bottom: 1.5rem;
  }

  .cta-dot {
    width: 8px;
    height: 8px;
    background: var(--accent-green);
    border-radius: 50%;
    animation: pulse-dot 2s ease-in-out infinite;
  }

  @keyframes pulse-dot {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  .cta-title {
    font-size: clamp(2rem, 4vw, 2.75rem);
    margin-bottom: 1rem;
  }

  .cta-description {
    margin-bottom: 2.5rem;
    max-width: 520px;
  }

  /* Form */
  .cta-form {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    margin-bottom: 1.5rem;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    text-align: left;
  }

  .form-label {
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .form-input {
    padding: 0.85rem 1.15rem;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: var(--radius-sm);
    color: var(--text-primary);
    font-family: var(--font-sans);
    font-size: 0.92rem;
    transition: all var(--transition-fast);
    outline: none;
  }

  .form-input::placeholder {
    color: var(--text-muted);
  }

  .form-input:focus {
    border-color: var(--accent-pink);
    background: rgba(255, 45, 117, 0.04);
    box-shadow: 0 0 0 3px rgba(255, 45, 117, 0.08);
  }

  .form-select {
    appearance: none;
    background-image: url("data:image/svg+xml,%3Csvg width='12' height='8' viewBox='0 0 12 8' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1.5L6 6.5L11 1.5' stroke='%236b6b80' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
    background-repeat: no-repeat;
    background-position: right 1rem center;
    padding-right: 2.5rem;
    cursor: pointer;
  }

  .form-select option {
    background: var(--bg-secondary);
    color: var(--text-primary);
  }

  .cta-submit {
    width: 100%;
    justify-content: center;
    padding: 1.1rem 2rem;
    font-size: 1.05rem;
    margin-top: 0.5rem;
  }

  .cta-disclaimer {
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  @media (max-width: 768px) {
    .cta-card {
      padding: 2.5rem 1.5rem;
    }

    .form-row {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  const form = document.getElementById('demo-form') as HTMLFormElement;
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    
    // Get form data
    const formData = new FormData(form);
    const name = formData.get('name');
    const email = formData.get('email');
    const company = formData.get('company') || 'No especificada';
    const role = formData.get('role') || 'No especificado';
    
    // Construct WhatsApp message
    const phoneNumber = '59179717725';
    const text = `🚀 *Nueva Solicitud de Demo - RestoFlow*\n\n*Nombre:* ${name}\n*Email:* ${email}\n*Empresa:* ${company}\n*Perfil:* ${role}\n\nHola! Me gustaría agendar una demostración en vivo del sistema.`;
    
    const encodedText = encodeURIComponent(text);
    const waUrl = `https://wa.me/${phoneNumber}?text=${encodedText}`;
    
    // Update UI briefly to show success before redirect
    const btn = document.getElementById('demo-submit');
    if (btn) {
      btn.innerHTML = '<span>✓ Redirigiendo a WhatsApp...</span>';
      btn.style.background = 'linear-gradient(135deg, #00e676, #00d4ff)';
    }

    // Redirect to WhatsApp
    setTimeout(() => {
        window.open(waUrl, '_blank');
        // Reset button
        if (btn) {
            btn.innerHTML = '<span>Agendar Demostración en Vivo</span><svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M4 10h12M12 6l4 4-4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>';
            btn.style.background = '';
        }
        form.reset();
    }, 800);
  });
</script>
